        {
          "name": "NEG_003_Negative Quantity",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", () => {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"API should reject negative quantity\", function () {\r",
                  "    const responsejson = pm.response.json();\r",
                  "    pm.expect(responsejson.success).to.not.include(\"Success\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"JSON body to contain errormessage\", () => {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    pm.expect(jsonData).to.not.be.empty;\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response time is less than 500ms\", function () {\r",
